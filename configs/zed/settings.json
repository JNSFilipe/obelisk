// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "terminal": {
    "keep_selection_on_copy": false,
    "copy_on_select": true,
    "option_as_meta": true,
  },
  "which_key": {
    "delay_ms": 100,
    "enabled": true,
  },
  "base_keymap": "Emacs",
  "ssh_connections": [
    {
      "host": "192.168.222.171",
      "username": "digiwest",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/digiwest/cilica"
          ]
        }
      ]
    },
    {
      "host": "100.64.0.60",
      "username": "digiwest",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/digiwest/camera-car-counting-smartparking"
          ]
        }
      ]
    },
    {
      "host": "100.64.0.60",
      "username": "digiwest",
      "args": [],
      "projects": []
    },
    {
      "host": "100.64.0.60",
      "username": "digiwest",
      "args": [],
      "projects": []
    }
  ],
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
    "model_parameters": [],
  },
  "vim_mode": true,
  "cursor_blink": false,
  // use relative line numbers
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show": false,
  },
  "scrollbar": {
    "show": "never",
  },
  // Indentation, rainbow indentation
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  // Inlay hints preconfigured by Zed: Go, Rust, Typescript and Svelte
  "inlay_hints": {
    "enabled": true,
  },
  // Theme and font size
  "ui_font_size": 13,
  "buffer_font_size": 12,
  "ui_font_family": "Iosevka",
  "buffer_font_family": "Iosevka",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    // "dark": "Oxocarbon Dark (IBM Carbon)"
    "dark": "Oxocarbon Dark (Variant II)",
  },
  // Turn off telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}

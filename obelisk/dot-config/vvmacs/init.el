;;; Perspective

;;; Perspective — workspace management

(use-package perspective
  :ensure t
  :bind (("C-x x x" . persp-switch)
         ("C-x x k" . persp-kill)
         ("C-x b"   . persp-switch-to-buffer*))
  :custom
  (persp-mode-prefix-key (kbd "C-x x"))
  :init
  (persp-mode))

(use-package persp-projectile
  :ensure t
  :after (perspective projectile)
  :config
  ;; Override the default 'p' key in projectile map to use perspectives
  (define-key projectile-command-map (kbd "p") #'projectile-persp-switch-project)
  ;; Remap projectile-switch-project to the perspective-aware version
  (with-eval-after-load 'projectile
    (define-key projectile-mode-map [remap projectile-switch-project] #'projectile-persp-switch-project)))



;;; Eglot (LSP)

;;; Eglot — Language Server Protocol client (built-in, Emacs 29+)

(use-package treesit-auto
  :ensure t
  :config
  (global-treesit-auto-mode))

(use-package eglot
  :ensure nil
  :hook
  ((python-mode     . (lambda () (when (executable-find "pylsp") (eglot-ensure))))
   (js-mode         . (lambda () (when (executable-find "typescript-language-server") (eglot-ensure))))
   (typescript-mode . (lambda () (when (executable-find "typescript-language-server") (eglot-ensure))))
   (rust-mode       . (lambda () (when (executable-find "rust-analyzer") (eglot-ensure))))
   (rust-ts-mode    . (lambda () (when (executable-find "rust-analyzer") (eglot-ensure))))
   (go-mode         . (lambda () (when (executable-find "gopls") (eglot-ensure))))
   (c-mode          . (lambda () (when (executable-find "clangd") (eglot-ensure))))
   (c++-mode        . (lambda () (when (executable-find "clangd") (eglot-ensure))))
   (c-ts-mode       . (lambda () (when (executable-find "clangd") (eglot-ensure))))
   (c++-ts-mode     . (lambda () (when (executable-find "clangd") (eglot-ensure)))))
  :config
  ;; Shut down the server when the last buffer for its project is closed
  (setq eglot-autoshutdown t)
  ;; Don't log server events unless debugging
  (setq eglot-events-buffer-size 0)

  ;; Ensure eldoc is snappy and shows all relevant info
  (setq eldoc-echo-area-use-multiline-p t
        eldoc-documentation-strategy 'eldoc-documentation-compose
        eldoc-idle-delay 0.1)

  ;; Enable automatic symbol highlighting at point
  (add-hook 'eglot-managed-mode-hook
            (lambda ()
              (add-hook 'post-command-hook #'eglot-highlight-symbol-at-point nil t))))


;;; Corfu (in-buffer completion)

;;; Corfu — in-buffer completion popup

(use-package corfu
  :ensure t
  :custom
  (corfu-auto t)           ; complete automatically
  (corfu-auto-delay 0.2)
  (corfu-cycle t)          ; wrap around candidate list
  (corfu-quit-no-match t)
  :init
  (global-corfu-mode)
  ;; Transfer completions to the minibuffer (for commands that use completing-read)
  (defun corfu-move-to-minibuffer ()
    (interactive)
    (let ((completion-extra-properties corfu--extra)
          completion-cycle-threshold completion-cycling)
      (apply #'consult-completion-in-region completion-in-region--data)))
  :bind (:map corfu-map ("M-m" . corfu-move-to-minibuffer)))


